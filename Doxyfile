PROJECT_NAME           = "Virtual Signal Conditioner"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Hardware-free real-time IMU signal conditioning pipeline"

OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

# Input
INPUT                  = include src README.md
FILE_PATTERNS          = *.hpp *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Extraction — pull everything even without \brief tags
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

# Appearance
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

# Diagrams — disabled (no Graphviz dependency required)
HAVE_DOT               = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

# Preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
